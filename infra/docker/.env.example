# 复制此文件为 .env，填入真实值后不要提交到 Git
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
LLM_MODEL=mimo-v2-omni
LLM_TEMPERATURE=0.1

# 安全密钥（生产环境必须修改！）
AUTH_SECRET=dev-auth-secret-change-me
WEBHOOK_SECRET=dev-webhook-secret-change-me
IOT_WEBHOOK_HMAC_SECRET=dev-iot-hmac-secret-change-me

# MiMo 模型变体
MIMO_ASR_MODEL=mimo-v2.5-asr
MIMO_TTS_MODEL=mimo-v2.5-tts
MIMO_OMNI_MODEL=mimo-v2-omni

# Langfuse Observability (可选)
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Concurrency Control (性能优化)
CONCURRENCY_ENABLED=true
CONCURRENCY_MAX_CONCURRENT_REQUESTS=30
CONCURRENCY_MAX_CONCURRENT_LLM_CALLS=15
CONCURRENCY_RAG_THREAD_POOL_SIZE=8
CONCURRENCY_LLM_ACQUIRE_TIMEOUT=30

# RAG 嵌入模型 (中文医学文本推荐 BAAI/bge-large-zh-v1.5)
RAG_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# RAG Cross-Encoder 重排模型 (可选，开启后检索精度显著提升)
RAG_RERANKER_ENABLED=false
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# 飞书告警 (可选)
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=
FEISHU_ALERT_ENABLED=false

# 定时科普（Cron 按此时区解释）
SCHEDULER_TIMEZONE=Asia/Shanghai
SCHEDULED_TASK_POLL_SECONDS=30
