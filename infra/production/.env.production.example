# Public site address. Start with http://SERVER_PUBLIC_IP when no domain is
# available. After DNS and ICP filing are ready, use https://health.example.com.
SITE_ADDRESS=http://203.0.113.10
PUBLIC_ORIGIN=http://203.0.113.10

# Database and Redis
POSTGRES_DB=medhelpagent
POSTGRES_USER=medhelp
POSTGRES_PASSWORD=replace-with-a-long-random-password
REDIS_PASSWORD=replace-with-a-different-long-random-password

# Required application secrets. Generate each independently with: openssl rand -hex 32
AUTH_SECRET=replace-with-a-random-secret
WEBHOOK_SECRET=replace-with-a-different-random-secret
IOT_WEBHOOK_HMAC_SECRET=replace-with-another-random-secret

# OpenAI-compatible model endpoint
OPENAI_API_KEY=replace-with-your-api-key
OPENAI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
LLM_MODEL=mimo-v2-omni
LLM_TEMPERATURE=0.1

# Low-memory production defaults for a 4 GB server
RAG_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
RAG_RERANKER_ENABLED=false
SCHEDULER_TIMEZONE=Asia/Shanghai
SCHEDULED_TASK_POLL_SECONDS=30

# Optional integrations
FEISHU_ALERT_ENABLED=false
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
SENTRY_DSN=

# Backups
BACKUP_RETENTION_DAYS=14
BACKUP_INTERVAL_SECONDS=86400
